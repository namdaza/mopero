<?xml version="1.0"?>
<robot name="logistics_robot">

  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>


  <link name="base_link">
    <visual>
      <origin xyz="0.242 -0.242 0" rpy="1.5708 0 1.5708"/>
      <geometry>
        <mesh filename="package://my_robot_description/meshes/base_link.stl"/>
      </geometry>
      <material name="white">
        <color rgba="0 0.2 0.7 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.58" rpy="0 0 0"/>
      <geometry>
        <box size="0.484 0.484 1.1"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.55" rpy="0 0 0"/>
      <mass value="10.0"/>
      <inertia ixx="1.2" ixy="0.0" ixz="0.0" iyy="1.2" iyz="0.0" izz="0.39"/>
    </inertial>
  </link>

  <link name="left_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.085" length="0.024"/>
      </geometry>
      <material name="black">
        <color rgba="0.2 0.2 0.2 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.085" length="0.024"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.00185" ixy="0.0" ixz="0.0" iyy="0.00185" iyz="0.0" izz="0.00361"/>
    </inertial>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="0 0.1923 0.085" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="1.5" velocity="2.3"/>
  </joint>

  <link name="right_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.085" length="0.024"/>
      </geometry>
      <material name="black">
        <color rgba="0.2 0.2 0.2 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.085" length="0.024"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.00185" ixy="0.0" ixz="0.0" iyy="0.00185" iyz="0.0" izz="0.00361"/>
    </inertial>
  </link>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="0 -0.1923 0.085" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="1.5" velocity="2.3"/>
  </joint>

  <link name="lidar_link">
    <visual>
      <geometry>
        <cylinder radius="0.05" length="0.04"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.05" length="0.04"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="0.25 0 0.265" rpy="0 0 0"/>
  </joint>

  <gazebo reference="lidar_link">
    <material>Gazebo/Black</material>
    <sensor name="lidar" type="ray">
      <pose>0 0 0 0 0 0</pose>
      <visualize>true</visualize>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>160</samples>
            <resolution>1.0</resolution>
            <min_angle>0</min_angle>
            <max_angle>1.396</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.15</min>
          <max>12.0</max>
          <resolution>0.015</resolution>
        </range>
      </ray>
      <plugin name="scan" filename="libgazebo_ros_ray_sensor.so">
        <ros>
          <remapping>~/out:=scan</remapping>
        </ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>lidar_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <link name="camera_link">
    <visual>
      <geometry>
        <box size="0.02 0.08 0.04"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.02 0.08 0.04"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0.22 0 1.13" rpy="0 0.09 0"/>
  </joint>

  <link name="camera_link_optical"></link>
  <joint name="camera_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_link_optical"/>
    <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/>
  </joint>

  <!-- Sonar Center -->
  <link name="sonar_center_link">
    <visual>
      <geometry><box size="0.01 0.04 0.02"/></geometry>
      <material name="black"/>
    </visual>
  </link>
  <joint name="sonar_center_joint" type="fixed">
    <parent link="base_link"/>
    <child link="sonar_center_link"/>
    <origin xyz="0.24 0 0.1" rpy="0 0 0"/>
  </joint>

  <!-- Sonar Left (Về mặt hình học đổi sang bên phải để bù trừ cắm ngược dây) -->
  <link name="sonar_left_link">
    <visual>
      <geometry><box size="0.01 0.04 0.02"/></geometry>
      <material name="black"/>
    </visual>
  </link>
  <joint name="sonar_left_joint" type="fixed">
    <parent link="base_link"/>
    <child link="sonar_left_link"/>
    <origin xyz="0.24 -0.15 0.1" rpy="0 0 -0.785"/>
  </joint>

  <!-- Sonar Right (Đảo sang trái) -->
  <link name="sonar_right_link">
    <visual>
      <geometry><box size="0.01 0.04 0.02"/></geometry>
      <material name="black"/>
    </visual>
  </link>
  <joint name="sonar_right_joint" type="fixed">
    <parent link="base_link"/>
    <child link="sonar_right_link"/>
    <origin xyz="0.24 0.15 0.1" rpy="0 0 0.785"/>
  </joint>

  <gazebo reference="camera_link">
    <material>Gazebo/Black</material>
    <sensor type="camera" name="camera">
      <pose>0 0 0 0 0 0</pose>
      <visualize>true</visualize>
      <update_rate>30.0</update_rate>
      <camera>
        <horizontal_fov>1.089</horizontal_fov>
        <image>
          <format>R8G8B8</format>
          <width>640</width>
          <height>480</height>
        </image>
        <clip>
          <near>0.05</near>
          <far>8.0</far>
        </clip>
      </camera>
      <plugin name="camera_controller" filename="libgazebo_ros_camera.so">
        <frame_name>camera_link_optical</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <link name="caster_linkf">
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.04"/> 
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="caster_jointf" type="fixed">
    <parent link="base_link"/>
    <child link="caster_linkf"/>
    <origin xyz="0.2 0 0.04" rpy="0 0 0"/> 
  </joint>

  <gazebo reference="caster_linkf">
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
    <material>Gazebo/Grey</material>
  </gazebo>

  <link name="caster_linkb">
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.04"/> 
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="caster_jointb" type="fixed">
    <parent link="base_link"/>
    <child link="caster_linkb"/>
    <origin xyz="-0.2 0 0.04" rpy="0 0 0"/> 
  </joint>

  <gazebo reference="caster_linkb">
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
    <material>Gazebo/Grey</material>
  </gazebo>

  <gazebo>
    <plugin name="diff_drive" filename="libgazebo_ros_diff_drive.so">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.3846</wheel_separation>
      <wheel_diameter>0.17</wheel_diameter>
      <max_wheel_torque>1.5</max_wheel_torque>
      <max_wheel_acceleration>1.0</max_wheel_acceleration>
      <command_topic>cmd_vel</command_topic>
      <odometry_topic>odom</odometry_topic>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_footprint</robot_base_frame>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>true</publish_wheel_tf>
    </plugin>
  </gazebo>

  <gazebo reference="base_link">
    <material>Gazebo/Orange</material>
  </gazebo>

  <gazebo reference="left_wheel">
    <material>Gazebo/Black</material>
  </gazebo>

  <gazebo reference="right_wheel">
    <material>Gazebo/Black</material>
  </gazebo>

</robot>
