# Google Gemini API key (Required for Speech-to-Text and AI assistant conversations)
# Get your Gemini API key from Google AI Studio: https://aistudio.google.com/
API_KEY=your_gemini_api_key_here

# Google Gemini model to use (Optional, defaults to gemini-2.5-flash)
# Supported models include: gemini-2.5-flash, gemini-1.5-flash, etc.
AI_MODEL=gemini-2.5-flash

# Port for the AI assistant server (Optional, defaults to 5001)
AI_PORT=5001
